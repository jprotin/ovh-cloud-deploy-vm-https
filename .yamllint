extends: default

rules:
  line-length:
    max: 140
    level: warning
  comments:
    min-spaces-from-content: 1
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
  indentation:
    spaces: 2
    indent-sequences: consistent
  document-start:
    present: true

ignore: |
  node_modules/
  .venv/
  vendor/
  dist/
  build/
  .terraform/
